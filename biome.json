{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "files": {
    "ignoreUnknown": true
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 80,
    "includes": [
      "**",
      "!**/.pytest_cache/",
      "!**/.direnv/",
      "!**/node_modules/",
      "!**/.venv/",
      "!**/build/",
      "!**/dist/",
      "!**/*.pyc",
      "!**/__pycache__/"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "none",
      "semicolons": "asNeeded"
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2,
      "lineEnding": "lf",
      "lineWidth": 80,
      "trailingCommas": "none"
    }
  }
}
